{
  "manifest_version": 3,
  "name": "Form Intelligence Tracker",
  "version": "1.1",
  "description": "Inject the FIS form tracker into any page and send events to your local analytics server.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Form Intelligence Tracker"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["html2canvas.min.js", "tracker-content.js"],
    "run_at": "document_idle"
  }]
}
